{
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "type": "string",
                "title": "Product Name",
                "minLength": 1
            },
            "description": {
                "type": "string",
                "title": "Description"
            },
            "price": {
                "type": "number",
                "title": "Price",
                "minimum": 0
            },
            "category": {
                "type": "string",
                "title": "Category",
                "enum": [
                    "Electronics",
                    "Clothing",
                    "Food",
                    "Other"
                ]
            },
            "inStock": {
                "type": "boolean",
                "title": "In Stock"
            }
        },
        "required": [
            "name",
            "price"
        ]
    },
    "uischema": {
        "type": "VerticalLayout",
        "elements": [
            {
                "type": "Control",
                "scope": "#/properties/name"
            },
            {
                "type": "Control",
                "scope": "#/properties/description",
                "options": {
                    "multi": true
                }
            },
            {
                "type": "HorizontalLayout",
                "elements": [
                    {
                        "type": "Control",
                        "scope": "#/properties/price"
                    },
                    {
                        "type": "Control",
                        "scope": "#/properties/category"
                    }
                ]
            },
            {
                "type": "Control",
                "scope": "#/properties/inStock"
            }
        ]
    }
}